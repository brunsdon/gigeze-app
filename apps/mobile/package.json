{
  "name": "@gigeze/mobile",
  "description": "GigEze mobile field app for trip capture and active trip workflows.",
  "version": "0.1.0",
  "private": true,
  "main": "index.js",
  "scripts": {
    "prestart": "node ../../scripts/sync-env-to-mobile.mjs",
    "start": "expo start",
    "start:usb": "expo start --localhost",
    "android": "expo run:android",
    "android:usb": "node ../../scripts/mobile-android-usb.mjs",
    "android:prod": "node ../../scripts/mobile-android-prod.mjs",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "expo lint",
    "test:run": "vitest run"
  },
  "dependencies": {
    "@expo/metro-config": "^54.0.0",
    "@gigeze/shared": "file:../../packages/shared",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@supabase/supabase-js": "^2.103.0",
    "expo": "^54.0.0",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "^18.0.0",
    "expo-dev-client": "~6.0.20",
    "expo-intent-launcher": "~13.0.7",
    "expo-keep-awake": "~15.0.8",
    "expo-location": "~19.0.8",
    "expo-status-bar": "^3.0.0",
    "expo-task-manager": "~14.0.9",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-maps": "1.20.1",
    "react-native-safe-area-context": "^5.7.0",
    "react-native-url-polyfill": "^3.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "~19.1.10",
    "eslint-config-expo": "~10.0.0",
    "typescript": "^5",
    "vitest": "^4.1.4"
  }
}
