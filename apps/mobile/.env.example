# Public Expo config only. Do not put service-role keys or private credentials here.
EXPO_PUBLIC_APP_ENV=development

# Supabase Auth client values. These should match apps/web/.env.
EXPO_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web API base URL used by completed-trip sync.
# Android emulator local web: http://10.0.2.2:3000
# Physical device: use a LAN, tunnel, or deployed HTTPS URL.
EXPO_PUBLIC_WEB_API_URL=http://10.0.2.2:3000

# Optional. Required only for native map rendering.
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
