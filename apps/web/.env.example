# App
NODE_ENV=development
NEXT_PUBLIC_APP_ENV=development
# Used for metadata and as a mobile sync fallback by scripts/sync-env-to-mobile.mjs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Optional local debug UI flag.
NEXT_PUBLIC_ENABLE_DEBUG_PANEL=false

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Optional locally unless your server-side storage workflow needs elevated access.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Local seed password for the auto-created admin auth user.
SEED_ADMIN_PASSWORD=dev-admin-password
# Optional. Leave unset for local-only database auth seeding.
SEED_SUPABASE_AUTH=false

# Prisma / PostgreSQL
DATABASE_URL=postgresql://postgres:postgres@localhost:51214/template1?sslmode=disable

# Supabase Storage
SUPABASE_STORAGE_BUCKET=media

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-javascript-api-key

# Mobile sync target for Expo/Android emulator. Use your LAN/tunnel/deployed URL for physical devices.
EXPO_PUBLIC_WEB_API_URL=http://10.0.2.2:3000
