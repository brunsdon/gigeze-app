{
  "name": "@gigeze/web",
  "description": "GigEze web dashboard, planning, public sharing, and admin app.",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:lan": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:smoke": "vitest run src/tests/smoke",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:seed:gigeze-demo": "node prisma/seed-gigeze-demo.mjs",
    "db:seed:gigeze-demo:prod": "node prisma/seed-gigeze-demo.mjs --env-file .env.production.local",
    "db:dev:start": "prisma dev -d",
    "db:dev:start:win": "powershell.exe -NoProfile -ExecutionPolicy Bypass -Command \"$root=(Resolve-Path ..\\\\..).Path; $env:LOCALAPPDATA=Join-Path $root '.tmp\\\\prisma-localappdata'; $env:APPDATA=Join-Path $root '.tmp\\\\prisma-appdata'; $env:TEMP=Join-Path $root '.tmp\\\\prisma-temp'; $env:TMP=$env:TEMP; New-Item -ItemType Directory -Force $env:LOCALAPPDATA, $env:APPDATA, $env:TEMP | Out-Null; prisma.cmd dev --db-port 51214 -d\"",
    "db:dev:stop": "prisma dev stop default",
    "db:dev:ls": "prisma dev ls",
    "db:health": "echo SELECT 1; | npx prisma db execute --stdin"
  },
  "prisma": {
    "seed": "node prisma/seed.mjs"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@hookform/resolvers": "^5.2.2",
    "@gigeze/shared": "file:../../packages/shared",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@supabase/ssr": "^0.10.0",
    "@supabase/supabase-js": "^2.101.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.7.0",
    "next": "16.2.2",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-hook-form": "^7.72.1",
    "shadcn": "^4.1.2",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "jsdom": "^29.0.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.2"
  }
}
